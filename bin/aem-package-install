#!/bin/bash
set -euo pipefail

tmp_files=()

cleanup() {
  local file

  for file in "${tmp_files[@]:-}"; do
    [[ -n "$file" && -e "$file" ]] && rm -f "$file"
  done

  return 0
}

trap cleanup EXIT

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

shell_quote() {
  printf '%q' "$1"
}

usage() {
  cat <<'USAGE'
Usage: aem-package-install [--dry-run] [--shallow] [-p PORT] [-u USER] [-P PASS] [-l] package.zip
       aem-package-install help

Installs an AEM content package using Package Manager with Extract Only,
so no snapshot is created.

Options:
  --dry-run  Show resolved settings and curl commands without executing them.
  --shallow  Do not extract embedded subpackages.
  -p PORT   Target AEM port. If omitted, auto-detect running AEM instances.
  -u USER   Username. Default: admin
  -P PASS   Password. Default: admin
  -l        List detected AEM ports and exit.
  -h        Show help.

Behavior:
  - If one AEM instance is running, its port is used automatically.
  - If multiple AEM instances are running in an interactive terminal,
    a picker is shown with arrow keys and j/k navigation.
  - Subpackages are extracted by default; pass --shallow to disable that.
  - Upload uses curl's progress bar when stderr is a TTY.
  - Install shows a spinner with elapsed time while AEM processes the package.

Examples:
  aem-package-install my-package.zip
  aem-package-install --dry-run my-package.zip
  aem-package-install --shallow my-package.zip
  aem-package-install -p 4502 my-package.zip
  aem-package-install -u admin -P admin my-package.zip
  aem-package-install -l
USAGE
}

is_aem_process_cmd() {
  local cmd="$1"

  [[ "$cmd" == *java* ]] || return 1
  [[ "$cmd" =~ quickstart|crx-quickstart|cq-quickstart|sling\.home|sling\.run\.modes|oak\.segment|oak\.tar|aem-.*\.jar|(^|[[:space:]])-p[1-9][0-9]{3,4}([[:space:]]|$)|(^|[[:space:]])-port(=|[[:space:]])[1-9][0-9]{3,4}([[:space:]]|$) ]]
}

extract_ports_from_cmd() {
  local cmd="$1"

  printf '%s\n' "$cmd" | grep -oE -- '(^|[[:space:]])-p[1-9][0-9]{3,4}([[:space:]]|$)' | grep -oE '[1-9][0-9]{3,4}' || true
  printf '%s\n' "$cmd" | grep -oE -- '(^|[[:space:]])-port(=|[[:space:]])[1-9][0-9]{3,4}([[:space:]]|$)' | grep -oE '[1-9][0-9]{3,4}' || true
  printf '%s\n' "$cmd" | grep -oE -- '[^[:space:]]+-p[1-9][0-9]{3,4}[^[:space:]]*\.jar' | grep -oE '[1-9][0-9]{3,4}' || true
}

list_listening_ports_for_pid() {
  local pid="$1"

  if command -v lsof >/dev/null 2>&1; then
    lsof -Pan -a -p "$pid" -iTCP -sTCP:LISTEN 2>/dev/null | \
      awk 'NR > 1 { n = split($9, parts, ":"); port = parts[n]; if (port ~ /^[0-9]+$/) print port }'
  fi
}

list_docker_entries() {
  local container_id line host_port

  command -v docker >/dev/null 2>&1 || return 0
  docker ps --format '{{.ID}}' 2>/dev/null | while IFS= read -r container_id; do
    [[ -n "$container_id" ]] || continue

    docker port "$container_id" 2>/dev/null | while IFS= read -r line; do
      host_port="$(printf '%s\n' "$line" | sed -nE 's/.*:([0-9]+)$/\1/p')"
      [[ -n "$host_port" ]] || continue
      is_probable_aem_port "$host_port" && printf '%s\t%s\n' "$host_port" "docker"
    done
  done || true

  return 0
}

is_probable_aem_port() {
  local port="$1"
  local path code

  for path in \
    /system/console/bundles.json \
    /crx/packmgr/service/.json \
    /system/console/status-slingsettings.json; do
    code="$(curl --globoff -s -u admin:admin -o /dev/null -w '%{http_code}' --max-time 1 "http://127.0.0.1:${port}${path}" 2>/dev/null || true)"
    case "$code" in
      200|302|401|403)
        return 0
        ;;
    esac
  done

  return 1
}

list_process_entries() {
  local line pid cmd explicit_port

  ps axww -o pid=,command= | while IFS= read -r line; do
    pid="${line%% *}"
    cmd="${line#"$pid"}"
    cmd="${cmd# }"

    is_aem_process_cmd "$cmd" || continue

    if explicit_port="$(extract_ports_from_cmd "$cmd")" && [[ -n "$explicit_port" ]]; then
      while IFS= read -r port; do
        [[ -n "$port" ]] && printf '%s\t%s\n' "$port" "local"
      done < <(printf '%s\n' "$explicit_port")
      continue
    fi

    while IFS= read -r port; do
      [[ -n "$port" ]] || continue
      is_probable_aem_port "$port" && printf '%s\t%s\n' "$port" "local"
    done < <(list_listening_ports_for_pid "$pid")
  done || true

  return 0
}

list_ports() {
  {
    list_process_entries
    list_docker_entries
  } | sort -t $'\t' -k1,1n -k2,2 | awk -F '\t' '!seen[$1]++' || true

  return 0
}

entry_port() {
  printf '%s\n' "${1%%$'\t'*}"
}

entry_label() {
  local entry="$1"

  if [[ "$entry" == *$'\t'* ]]; then
    printf '%s\n' "${entry#*$'\t'}"
  else
    printf 'local\n'
  fi
}

url_encode() {
  local input="$1"
  local output=""
  local i char

  LC_ALL=C
  for ((i = 0; i < ${#input}; i++)); do
    char="${input:i:1}"
    case "$char" in
      [a-zA-Z0-9.~_/-]) output+="$char" ;;
      *) printf -v output '%s%%%02X' "$output" "'$char" ;;
    esac
  done

  printf '%s\n' "$output"
}

has_status_tty() {
  [[ -t 2 ]]
}

curl_with_progress() {
  if has_status_tty; then
    curl --globoff -fS --progress-bar "$@"
  else
    curl --globoff -fsS "$@"
  fi
}

show_spinner() {
  local pid="$1"
  local label="$2"
  local start_ts now_ts elapsed
  local frames='-\|/'
  local i=0

  start_ts="$(date +%s)"

  while kill -0 "$pid" 2>/dev/null; do
    now_ts="$(date +%s)"
    elapsed=$((now_ts - start_ts))
    printf '\r[%c] %s (%02d:%02d)' "${frames:i++%${#frames}:1}" "$label" $((elapsed / 60)) $((elapsed % 60)) >&2
    sleep 0.1
  done

  local status
  if wait "$pid"; then
    status=0
  else
    status=$?
  fi
  now_ts="$(date +%s)"
  elapsed=$((now_ts - start_ts))

  if [[ $status -eq 0 ]]; then
    printf '\r[+] %s (%02d:%02d)\n' "$label" $((elapsed / 60)) $((elapsed % 60)) >&2
  else
    printf '\r[x] %s (%02d:%02d)\n' "$label" $((elapsed / 60)) $((elapsed % 60)) >&2
  fi

  return "$status"
}

interactive_pick_port() {
  local entries=("$@")
  local selected=0
  local key=""
  local key2=""
  local key3=""
  local rendered=0
  local lines=$(( ${#entries[@]} + 2 ))
  local old_stty
  local style_reset=$'\033[0m'
  local style_dim=$'\033[2m'
  local style_title=$'\033[38;5;120;1m'
  local style_selected=$'\033[48;5;22m\033[38;5;157m\033[1m'
  local style_selected_port=$'\033[48;5;22m\033[38;5;194m\033[1m'
  local style_selected_label=$'\033[48;5;22m\033[38;5;151m'
  local style_unselected=$'\033[38;5;114m'
  local style_label=$'\033[38;5;108m'
  local style_hint=$'\033[38;5;108m'

  old_stty="$(stty -g)"

  restore_terminal() {
    stty "$old_stty"
    tput cnorm >&2 2>/dev/null || true
  }

  render_menu() {
    local i port label

    if [[ $rendered -eq 1 ]]; then
      printf '\r\033[%dA\033[J' "$lines" >&2
    fi

    printf '%sSelect an AEM instance%s %s(up/down, j/k, Enter confirms)%s\n' \
      "$style_title" "$style_reset" "$style_dim" "$style_reset" >&2
    for i in "${!entries[@]}"; do
      port="$(entry_port "${entries[$i]}")"
      label="$(entry_label "${entries[$i]}")"
      if [[ $i -eq $selected ]]; then
        printf '  %s[ %s%s%s ]  %s%s%s  active AEM instance%s\n' \
          "$style_selected" "$style_selected_port" "$port" "$style_selected" \
          "$style_selected_label" "$label" "$style_selected" "$style_reset" >&2
      else
        printf '  %s  %s%s  %s[%s]%s\n' \
          "$style_unselected" "$port" "$style_reset" \
          "$style_label" "$label" "$style_reset" >&2
      fi
    done
    printf '%sPress q to cancel.%s\n' "$style_hint" "$style_reset" >&2

    rendered=1
  }

  trap 'restore_terminal; printf "\n" >&2; exit 130' INT TERM
  stty -echo -icanon time 1 min 0
  tput civis >&2 2>/dev/null || true

  render_menu

  while true; do
    if ! IFS= read -rsn1 key; then
      continue
    fi

    case "$key" in
      ""|$'\n'|$'\r')
        restore_terminal
        trap - INT TERM
        printf '\r\033[%dA\033[J' "$lines" >&2
        printf '%s\n' "$(entry_port "${entries[$selected]}")"
        return
        ;;
      j)
        ((selected < ${#entries[@]} - 1)) && ((selected++))
        ;;
      k)
        ((selected > 0)) && ((selected--))
        ;;
      q)
        restore_terminal
        trap - INT TERM
        printf '\r\033[%dA\033[J' "$lines" >&2
        echo "Selection cancelled." >&2
        exit 1
        ;;
      $'\x1b')
        IFS= read -rsn1 key2 || true
        IFS= read -rsn1 key3 || true
        case "${key2}${key3}" in
          "[A") ((selected > 0)) && ((selected--)) ;;
          "[B") ((selected < ${#entries[@]} - 1)) && ((selected++)) ;;
        esac
        ;;
    esac

    render_menu
  done
}

pick_port() {
  local entries=()
  local entry
  local summary=()

  while IFS= read -r entry; do
    [[ -n "$entry" ]] && entries+=("$entry")
  done < <(list_ports)

  if [[ ${#entries[@]} -eq 0 ]]; then
    echo "No running AEM instances detected via local processes or Docker-published ports." >&2
    exit 1
  fi

  if [[ ${#entries[@]} -eq 1 ]]; then
    printf '%s\n' "$(entry_port "${entries[0]}")"
    return
  fi

  if [[ -t 0 && -t 2 ]]; then
    interactive_pick_port "${entries[@]}"
    return
  fi

  while IFS= read -r entry; do
    summary+=("$(entry_port "$entry") ($(entry_label "$entry"))")
  done < <(printf '%s\n' "${entries[@]}")

  echo "Multiple running AEM instances detected: ${summary[*]}" >&2
  echo "Pass -p PORT to choose one." >&2
  exit 1
}

port=""
user="admin"
pass="admin"
list_only=0
recursive=true
dry_run=false

if [[ ${1:-} == "help" ]]; then
  usage
  exit 0
fi

if [[ $# -eq 0 ]]; then
  usage
  exit 2
fi

args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=true
      shift
      ;;
    --shallow)
      recursive=false
      shift
      ;;
    --help)
      usage
      exit 0
      ;;
    --)
      args+=("$1")
      shift
      while [[ $# -gt 0 ]]; do
        args+=("$1")
        shift
      done
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

set -- "${args[@]}"

while getopts ":p:u:P:lh" opt; do
  case "$opt" in
    p) port="$OPTARG" ;;
    u) user="$OPTARG" ;;
    P) pass="$OPTARG" ;;
    l) list_only=1 ;;
    h) usage; exit 0 ;;
    :) echo "Option -$OPTARG requires a value." >&2; usage; exit 2 ;;
    \?) echo "Unknown option: -$OPTARG" >&2; usage; exit 2 ;;
  esac
done
shift $((OPTIND - 1))

if [[ $list_only -eq 1 ]]; then
  list_ports
  exit 0
fi

if [[ $# -ne 1 ]]; then
  usage >&2
  exit 2
fi

pkg="$1"
[[ -f "$pkg" ]] || die "Package not found: $pkg"

if [[ -z "$port" ]]; then
  port="$(pick_port)"
fi

[[ "$port" =~ ^[1-9][0-9]{3,4}$ ]] || die "Invalid port: $port"

base="http://localhost:${port}"
upload_url="${base}/crx/packmgr/service/.json"

if [[ "$dry_run" == true ]]; then
  printf 'Dry run: no changes will be made.\n' >&2
  printf 'Resolved package: %s\n' "$(shell_quote "$pkg")" >&2
  printf 'Resolved port: %s\n' "$port" >&2
  printf 'Recursive install: %s\n' "$recursive" >&2
  printf 'Upload URL: %s\n' "$upload_url" >&2
  printf 'Upload command:\n' >&2
  printf '  curl --globoff -u %s -F cmd=upload -F force=true -F package=@%s %s\n' \
    "$(shell_quote "$user:$pass")" \
    "$(shell_quote "$pkg")" \
    "$(shell_quote "$upload_url")" >&2
  printf 'Install command:\n' >&2
  printf '  curl --globoff -u %s -X POST -F cmd=install -F recursive=%s -F extractOnly=true %s<uploaded-package-path>\n' \
    "$(shell_quote "$user:$pass")" \
    "$recursive" \
    "$(shell_quote "${base}/crx/packmgr/service/.json")" >&2
  exit 0
fi

echo "Uploading package to AEM on port ${port}..." >&2
upload_resp="$(curl_with_progress -u "$user:$pass" \
  -F cmd=upload \
  -F force=true \
  -F package=@"$pkg" \
  "$upload_url")"

pkg_path="$(printf '%s' "$upload_resp" | sed -nE 's/.*"path":"([^"]+)".*/\1/p')"
if [[ -z "$pkg_path" ]]; then
  echo "Upload succeeded but package path could not be parsed." >&2
  echo "$upload_resp" >&2
  exit 1
fi

install_url="${base}/crx/packmgr/service/.json$(url_encode "$pkg_path")"
echo "Installing package in extract-only mode..." >&2

if has_status_tty; then
  install_resp_file="$(mktemp)"
  tmp_files+=("$install_resp_file")

  curl --globoff -fsS -u "$user:$pass" -X POST \
    -F cmd=install \
    -F recursive="$recursive" \
    -F extractOnly=true \
    "$install_url" >"$install_resp_file" &
  install_pid=$!

  if ! show_spinner "$install_pid" "Waiting for AEM to finish installation"; then
    install_resp="$(<"$install_resp_file")"
    [[ -n "$install_resp" ]] && echo "$install_resp" >&2
    exit 1
  fi

  install_resp="$(<"$install_resp_file")"
else
  install_resp="$(curl --globoff -fsS -u "$user:$pass" -X POST \
    -F cmd=install \
    -F recursive="$recursive" \
    -F extractOnly=true \
    "$install_url")"
fi

if printf '%s' "$install_resp" | grep -q '"success":true'; then
  echo "Installed extract-only to AEM on port ${port}: ${pkg_path}"
else
  echo "Install request did not report success." >&2
  echo "$install_resp" >&2
  exit 1
fi
